# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains private keys.
#
# For Phase 1 dry run (read-only data collection), only DRY_RUN=true and
# the CLOB_HOST / CHAIN_ID lines are required. Wallet credentials are only
# needed for Phase 2 live trading.

# =============================================================================
# PHASE 2 ONLY — Wallet / authentication credentials
# =============================================================================
# These are only required when DRY_RUN=false (live order placement).
# Leave as placeholders during the Phase 1 24-hour dry run.

# Your Polymarket proxy wallet private key (0x...).
# Obtain via: python -m polybot.derive_creds  (creates a proxy wallet)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polymarket CLOB HMAC API credentials (L2 auth for order placement).
# Derive from your proxy wallet private key.
API_KEY=YOUR_API_KEY
API_SECRET=YOUR_API_SECRET
API_PASSPHRASE=YOUR_API_PASSPHRASE

# Your Polymarket account address (0x...) — the wallet that holds USDC.
# This is the "funder" that the proxy wallet signs on behalf of.
FUNDER=0xYOUR_POLYMARKET_ACCOUNT_ADDRESS

# =============================================================================
# REQUIRED — Infrastructure (safe to leave at defaults)
# =============================================================================

# Polymarket CLOB REST host. Do not change.
CLOB_HOST=https://clob.polymarket.com

# Polygon mainnet. Do not change.
CHAIN_ID=137

# =============================================================================
# OPTIONAL — Venue endpoint overrides
# =============================================================================
# All default to production values in config.py. Only set these if you need
# to point to a testnet or a local proxy.

# BINANCE_WS_HOST=wss://stream.binance.com:9443
# POLY_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market
# POLY_RTDS_WS=wss://ws-live-data.polymarket.com
# COINBASE_WS_HOST=wss://advanced-trade-ws.coinbase.com
# GAMMA_API=https://gamma-api.polymarket.com
# POLYGON_RPC=https://polygon-rpc.com

# =============================================================================
# OPERATIONAL PARAMETERS
# =============================================================================

# --- Dry run ---
# true  = Phase 1: log all decisions, place NO real orders (safe, default)
# false = Phase 2: place real orders on Polymarket (requires wallet credentials above)
DRY_RUN=true

# --- Storage ---
# Where Parquet decision logs are written. Defaults to ./logs/ if not set.
# LOG_DIR=logs
# PARQUET_DIR=logs

# --- Fallback balance ---
# If the CLOB API returns 0 for your wallet balance (common on first run or
# during sync lag), the bot uses this value instead. Set to your actual
# deposited USDC amount. Leave at 0 during dry run.
FALLBACK_BALANCE=0

# =============================================================================
# STRATEGY PARAMETERS (normally left at defaults from config.py)
# =============================================================================
# These are in config.py with hardcoded defaults. Setting them here overrides.

# Minimum net edge (probability points) to enter a trade.
# 0.02 = lowest Kelly tier floor. Raise to 0.04 for more conservative entries.
# EPSILON=0.02

# Scheduler tick interval in seconds. Keep at 10.
# POLL_INTERVAL=10
