# Copy this file to .env on the server and fill in real values.
# NEVER commit .env to git.

# Polygon wallet private key (the wallet linked to your Polymarket account)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polymarket CLOB API credentials
# If you don't have these yet, run: python3 test_trade.py --derive-creds
API_KEY=YOUR_API_KEY
API_SECRET=YOUR_API_SECRET
API_PASSPHRASE=YOUR_API_PASSPHRASE

# Polymarket CLOB host (do not change)
CLOB_HOST=https://clob.polymarket.com

# Chain ID: 137 = Polygon Mainnet (do not change)
CHAIN_ID=137

# Your Polymarket account address (the 0x... shown on your Polymarket profile).
# Required when PRIVATE_KEY is a relayer/API signing key rather than your
# main account key — the funder is the address that actually holds USDC.
FUNDER=0xe0906dC6378bf7370D3592aE8F5D9d9A80B2fCe2

# --- Bot operational parameters (override model defaults if needed) ---

# Edge threshold: minimum delta = p_mine - q to enter a trade
# Phase 1 (conservative): 0.04
# Phase 2 (full model):   0.02
EPSILON=0.02

# Poll interval in seconds
POLL_INTERVAL=10

# Dry run: set to true to log trades without placing real orders
DRY_RUN=true

# Fallback wallet balance in USD if get_balance_allowance returns 0.
# Set this to your actual deposited balance until the CLOB API reflects it.
# Leave at 0 to disable (bot will skip loops when balance is unreadable).
FALLBACK_BALANCE=0
